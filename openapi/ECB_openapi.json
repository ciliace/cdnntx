{
  "swagger": "2.0",
  "info": {
    "title": "Frankfurter Exchange Rates API",
    "description": "European Central Bank exchange rates. No API key required.",
    "version": "1.0.0"
  },
  "host": "api.frankfurter.dev",
  "basePath": "/v1",
  "schemes": ["https"],
  "produces": ["application/json"],
  "paths": {
    "/latest": {
      "get": {
        "summary": "Get latest CHF exchange rate",
        "operationId": "getLatestRates",
        "parameters": [
          {
            "name": "base",
            "in": "query",
            "required": false,
            "type": "string",
            "default": "EUR"
          },
          {
            "name": "symbols",
            "in": "query",
            "required": false,
            "type": "string",
            "default": "CHF"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "schema": {
              "$ref": "#/definitions/Rates"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "Rates": {
      "type": "object",
      "properties": {
        "amount": { "type": "number", "format": "float" },
        "base":   { "type": "string" },
        "date":   { "type": "string" }
      }
    }
  }
}
